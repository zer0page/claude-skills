#!/usr/bin/env bash
# Unit tests for ci-poll.sh and ci-loop.sh.
# Mocks gh and jq responses to test script logic without network calls.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
POLL_SCRIPT="$SCRIPT_DIR/ci-poll.sh"
LOOP_SCRIPT="$SCRIPT_DIR/ci-loop.sh"
TMPDIR_BASE=$(mktemp -d)
passed=0
failed=0

cleanup() { rm -rf "$TMPDIR_BASE"; }
trap cleanup EXIT

pass() { passed=$((passed + 1)); echo "  PASS: $1"; }
fail() { failed=$((failed + 1)); echo "  FAIL: $1"; }

assert_json() {
  local json="$1" path="$2" expected="$3" label="$4"
  actual=$(echo "$json" | jq -r "$path")
  if [ "$actual" = "$expected" ]; then
    pass "$label"
  else
    fail "$label (expected '$expected', got '$actual')"
  fi
}

# --- Create mock gh script ---
MOCK_DIR="$TMPDIR_BASE/mocks"
MOCK_GH="$MOCK_DIR/gh"
mkdir -p "$MOCK_DIR"

create_mock_gh() {
  local response_dir="$1"
  cat > "$MOCK_GH" << 'GHEOF'
#!/usr/bin/env bash
RESPONSE_DIR="__RESPONSE_DIR__"

# Extract --jq filter if present
JQ_FILTER=""
args=("$@")
for i in "${!args[@]}"; do
  if [ "${args[$i]}" = "--jq" ] && [ $((i+1)) -lt ${#args[@]} ]; then
    JQ_FILTER="${args[$((i+1))]}"
    break
  fi
done

apply_jq() {
  if [ -n "$JQ_FILTER" ]; then
    jq -r "$JQ_FILTER"
  else
    cat
  fi
}

case "$*" in
  *"pr view"*"headRefOid"*"statusCheckRollup"*|*"pr view"*"statusCheckRollup"*"headRefOid"*)
    # Combined fetch — build JSON from separate response files
    _sha=$(cat "$RESPONSE_DIR/head_sha" 2>/dev/null)
    _checks=$(cat "$RESPONSE_DIR/checks" 2>/dev/null)
    _merge=$(cat "$RESPONSE_DIR/merge_state" 2>/dev/null)
    printf '{"headRefOid":"%s","statusCheckRollup":%s,"mergeStateStatus":"%s"}' "$_sha" "$_checks" "$_merge" ;;
  *"pr view"*"headRefOid"*)
    cat "$RESPONSE_DIR/head_sha" 2>/dev/null ;;
  *"pr view"*"statusCheckRollup"*)
    cat "$RESPONSE_DIR/checks" 2>/dev/null ;;
  *"pr view"*"mergeStateStatus"*)
    cat "$RESPONSE_DIR/merge_state" 2>/dev/null ;;
  *"api"*"reviews"*"comments"*)
    cat "$RESPONSE_DIR/review_comments" 2>/dev/null | apply_jq ;;
  *"api"*"reviews"*)
    cat "$RESPONSE_DIR/reviews" 2>/dev/null | apply_jq ;;
  *"api"*"pulls/"*"/comments"*)
    cat "$RESPONSE_DIR/pr_comments" 2>/dev/null | apply_jq ;;
  *"run view"*)
    cat "$RESPONSE_DIR/run_logs" 2>/dev/null ;;
  *)
    echo "mock gh: unhandled: $*" >&2; exit 1 ;;
esac
GHEOF
  sed -i.bak "s|__RESPONSE_DIR__|$response_dir|g" "$MOCK_GH" 2>/dev/null || \
    sed -i '' "s|__RESPONSE_DIR__|$response_dir|g" "$MOCK_GH"
  rm -f "$MOCK_GH.bak"
  chmod +x "$MOCK_GH"
}

run_poll() {
  PATH="$MOCK_DIR:$PATH" bash "$POLL_SCRIPT" "$@"
}

run_loop() {
  PATH="$MOCK_DIR:$PATH" bash "$LOOP_SCRIPT" "$@"
}

# ============================================================
# ci-poll.sh tests
# ============================================================

echo "--- ci-poll.sh: all checks clean ---"
RESP="$TMPDIR_BASE/t1"
mkdir -p "$RESP"
echo "abc123" > "$RESP/head_sha"
cat > "$RESP/checks" << 'EOF'
[{"__typename":"CheckRun","name":"build","status":"COMPLETED","conclusion":"SUCCESS","detailsUrl":"https://example.com"},{"__typename":"StatusContext","context":"Kochiku","state":"SUCCESS","targetUrl":"https://example.com"}]
EOF
echo "CLEAN" > "$RESP/merge_state"
echo "[]" > "$RESP/reviews"
echo "[]" > "$RESP/pr_comments"
create_mock_gh "$RESP"

result=$(run_poll --pr 1 --repo owner/name --sha abc123)
assert_json "$result" '.sha_match' 'true' "sha_match is true"
assert_json "$result" '.checks | length' '2' "2 checks"
assert_json "$result" '[.checks[] | select(.resolved == false)] | length' '0' "0 pending"
assert_json "$result" '[.checks[] | select(.state == "SUCCESS")] | length' '2' "2 passed"
assert_json "$result" '.merge_state' 'CLEAN' "merge_state is CLEAN"

echo "--- ci-poll.sh: SHA mismatch ---"
result=$(run_poll --pr 1 --repo owner/name --sha wrong_sha)
assert_json "$result" '.sha_match' 'false' "sha_match is false on mismatch"
assert_json "$result" '.head_sha' 'abc123' "returns actual head_sha"

echo "--- ci-poll.sh: mixed failures (CheckRun + StatusContext) ---"
RESP="$TMPDIR_BASE/t3"
mkdir -p "$RESP"
echo "abc123" > "$RESP/head_sha"
cat > "$RESP/checks" << 'EOF'
[{"__typename":"CheckRun","name":"build","status":"COMPLETED","conclusion":"SUCCESS","detailsUrl":"https://example.com"},{"__typename":"StatusContext","context":"Kochiku","state":"FAILURE","targetUrl":"https://kochiku.example.com"},{"__typename":"StatusContext","context":"Task List","state":"ERROR","targetUrl":"https://example.com/tasks"}]
EOF
echo "BLOCKED" > "$RESP/merge_state"
echo "[]" > "$RESP/reviews"
echo "[]" > "$RESP/pr_comments"
create_mock_gh "$RESP"

result=$(run_poll --pr 1 --repo owner/name --sha abc123)
assert_json "$result" '[.checks[] | select(.state == "FAILURE" or .state == "ERROR")] | length' '2' "2 non-success checks"
assert_json "$result" '[.checks[] | select(.state == "FAILURE")][0].type' 'StatusContext' "first failure is StatusContext"
assert_json "$result" '[.checks[] | select(.state == "FAILURE")][0].state' 'FAILURE' "raw state is FAILURE"
assert_json "$result" '.merge_state' 'BLOCKED' "merge_state is BLOCKED"

echo "--- ci-poll.sh: pending checks ---"
RESP="$TMPDIR_BASE/t4"
mkdir -p "$RESP"
echo "abc123" > "$RESP/head_sha"
cat > "$RESP/checks" << 'EOF'
[{"__typename":"CheckRun","name":"build","status":"IN_PROGRESS","conclusion":null,"detailsUrl":"https://example.com"},{"__typename":"StatusContext","context":"Kochiku","state":"PENDING","targetUrl":"https://example.com"}]
EOF
echo "BLOCKED" > "$RESP/merge_state"
echo "[]" > "$RESP/reviews"
echo "[]" > "$RESP/pr_comments"
create_mock_gh "$RESP"

result=$(run_poll --pr 1 --repo owner/name --sha abc123)
assert_json "$result" '[.checks[] | select(.resolved == false)] | length' '2' "2 pending checks"
assert_json "$result" '[.checks[] | select(.resolved == true)] | length' '0' "0 resolved (still pending)"

echo "--- ci-poll.sh: review bot with comments (raw state) ---"
RESP="$TMPDIR_BASE/t5"
mkdir -p "$RESP"
echo "abc123" > "$RESP/head_sha"
cat > "$RESP/checks" << 'EOF'
[{"__typename":"CheckRun","name":"build","status":"COMPLETED","conclusion":"SUCCESS","detailsUrl":"https://example.com"}]
EOF
echo "CLEAN" > "$RESP/merge_state"
echo '[{"id":99,"state":"COMMENTED","user":{"login":"bot[bot]"},"commit_id":"abc123"}]' > "$RESP/reviews"
echo '[{"id":1,"path":"file.txt","body":"fix this"}]' > "$RESP/review_comments"
echo "[]" > "$RESP/pr_comments"
create_mock_gh "$RESP"

result=$(run_poll --pr 1 --repo owner/name --sha abc123 --review-bot "bot[bot]")
assert_json "$result" '.review_state' 'COMMENTED' "raw review_state is COMMENTED"
assert_json "$result" '.review_comment_count' '1' "review has 1 comment"
assert_json "$result" '.review_id' '99' "review_id returned"

echo "--- ci-poll.sh: review bot approved (raw state) ---"
RESP="$TMPDIR_BASE/t6"
mkdir -p "$RESP"
echo "abc123" > "$RESP/head_sha"
cat > "$RESP/checks" << 'EOF'
[{"__typename":"CheckRun","name":"build","status":"COMPLETED","conclusion":"SUCCESS","detailsUrl":"https://example.com"}]
EOF
echo "CLEAN" > "$RESP/merge_state"
echo '[{"id":99,"state":"APPROVED","user":{"login":"bot[bot]"},"commit_id":"abc123"}]' > "$RESP/reviews"
echo '[]' > "$RESP/review_comments"
echo "[]" > "$RESP/pr_comments"
create_mock_gh "$RESP"

result=$(run_poll --pr 1 --repo owner/name --sha abc123 --review-bot "bot[bot]")
assert_json "$result" '.review_state' 'APPROVED' "raw review_state is APPROVED"
assert_json "$result" '.review_comment_count' '0' "0 review comments"

echo "--- ci-poll.sh: no review bot ---"
RESP="$TMPDIR_BASE/t7"
mkdir -p "$RESP"
echo "abc123" > "$RESP/head_sha"
cat > "$RESP/checks" << 'EOF'
[{"__typename":"CheckRun","name":"build","status":"COMPLETED","conclusion":"SUCCESS","detailsUrl":"https://example.com"}]
EOF
echo "CLEAN" > "$RESP/merge_state"
echo "[]" > "$RESP/pr_comments"
create_mock_gh "$RESP"

result=$(run_poll --pr 1 --repo owner/name --sha abc123)
assert_json "$result" '.review_state' 'null' "review_state is null when no bot configured"
assert_json "$result" '.review_id' 'null' "review_id is null"

# ============================================================
# ci-loop.sh tests
# ============================================================

echo "--- ci-loop.sh: clean result (no failures, no comments) ---"
RESP="$TMPDIR_BASE/t8"
mkdir -p "$RESP"
echo "abc123" > "$RESP/head_sha"
cat > "$RESP/checks" << 'EOF'
[{"__typename":"CheckRun","name":"build","status":"COMPLETED","conclusion":"SUCCESS","detailsUrl":"https://example.com"}]
EOF
echo "CLEAN" > "$RESP/merge_state"
echo "[]" > "$RESP/reviews"
echo "[]" > "$RESP/pr_comments"
create_mock_gh "$RESP"

result=$(run_loop --pr 1 --repo owner/name --sha abc123)
assert_json "$result" '[.checks[] | select(.state == "SUCCESS")] | length' '1' "loop: 1 passed"
assert_json "$result" '[.checks[] | select(.resolved == false)] | length' '0' "loop: 0 pending"
assert_json "$result" '.review_bot_timeout' 'false' "loop: no bot timeout"
assert_json "$result" '.ci_logs' '' "loop: no ci_logs"

echo "--- ci-loop.sh: failure fetches logs ---"
RESP="$TMPDIR_BASE/t9"
mkdir -p "$RESP"
echo "abc123" > "$RESP/head_sha"
cat > "$RESP/checks" << 'EOF'
[{"__typename":"CheckRun","name":"build","status":"COMPLETED","conclusion":"FAILURE","detailsUrl":"https://github.com/owner/name/actions/runs/12345/job/67890"}]
EOF
echo "BLOCKED" > "$RESP/merge_state"
echo "[]" > "$RESP/reviews"
echo "[]" > "$RESP/pr_comments"
echo "Error: tests failed on line 42" > "$RESP/run_logs"
create_mock_gh "$RESP"

result=$(run_loop --pr 1 --repo owner/name --sha abc123)
assert_json "$result" '[.checks[] | select(.state == "FAILURE")] | length' '1' "loop: 1 failed check"
ci_logs=$(echo "$result" | jq -r '.ci_logs')
if echo "$ci_logs" | grep -q "Run 12345"; then
  pass "loop: ci_logs contains run ID"
else
  fail "loop: ci_logs missing run ID (got: $ci_logs)"
fi

echo "--- ci-loop.sh: SHA mismatch exits immediately ---"
result=$(run_loop --pr 1 --repo owner/name --sha wrong_sha)
assert_json "$result" '.sha_match' 'false' "loop: exits on SHA mismatch"

echo "--- ci-loop.sh: review comments trigger early return ---"
RESP="$TMPDIR_BASE/t10"
mkdir -p "$RESP"
echo "abc123" > "$RESP/head_sha"
cat > "$RESP/checks" << 'EOF'
[{"__typename":"CheckRun","name":"build","status":"IN_PROGRESS","conclusion":null,"detailsUrl":"https://example.com"}]
EOF
echo "BLOCKED" > "$RESP/merge_state"
echo '[{"id":99,"state":"COMMENTED","user":{"login":"bot[bot]"},"commit_id":"abc123"}]' > "$RESP/reviews"
echo '[{"id":1,"path":"file.txt","body":"fix this"}]' > "$RESP/review_comments"
echo "[]" > "$RESP/pr_comments"
create_mock_gh "$RESP"

result=$(run_loop --pr 1 --repo owner/name --sha abc123 --review-bot "bot[bot]")
assert_json "$result" '.review_comment_count' '1' "loop: review comments returned"
# CI still pending but loop returned early due to review comments
assert_json "$result" '[.checks[] | select(.resolved == false)] | length' '1' "loop: CI still pending (early return)"

# ============================================================
# Summary
# ============================================================
echo ""
echo "Results: $passed passed, $failed failed"
if [ $failed -gt 0 ]; then
  exit 1
fi
