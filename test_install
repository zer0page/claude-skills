#!/usr/bin/env bash
# Tests for the install script.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL="$SCRIPT_DIR/install"
TMPDIR_BASE=$(mktemp -d)
passed=0
failed=0

cleanup() { rm -rf "$TMPDIR_BASE"; }
trap cleanup EXIT

pass() { passed=$((passed + 1)); echo "  PASS: $1"; }
fail() { failed=$((failed + 1)); echo "  FAIL: $1"; }

# --- Test: install all skills into a project directory ---
proj="$TMPDIR_BASE/project1"
mkdir -p "$proj"
"$INSTALL" --project "$proj" > /dev/null

for skill in "$SCRIPT_DIR"/skills/*/; do
  name=$(basename "$skill")
  link="$proj/.claude/skills/$name"
  if [ -L "$link" ]; then
    pass "install all — $name symlinked"
  else
    fail "install all — $name not found"
  fi
done

# --- Test: idempotent reinstall ---
output=$("$INSTALL" --project "$proj" 2>&1)
if echo "$output" | grep -q "already linked"; then
  pass "idempotent reinstall"
else
  fail "idempotent reinstall — expected 'already linked'"
fi

# --- Test: --skill filter installs only one ---
proj2="$TMPDIR_BASE/project2"
mkdir -p "$proj2"
"$INSTALL" --project "$proj2" --skill audit > /dev/null

if [ -L "$proj2/.claude/skills/audit" ]; then
  pass "--skill filter — audit installed"
else
  fail "--skill filter — audit not installed"
fi

count=$(find "$proj2/.claude/skills" -maxdepth 1 -type l | wc -l | tr -d ' ')
if [ "$count" -eq 1 ]; then
  pass "--skill filter — only one skill installed"
else
  fail "--skill filter — expected 1 symlink, got $count"
fi

# --- Test: uninstall removes symlinks ---
"$INSTALL" --project "$proj" --uninstall > /dev/null
remaining=$(find "$proj/.claude/skills" -maxdepth 1 -type l 2>/dev/null | wc -l | tr -d ' ')
if [ "$remaining" -eq 0 ]; then
  pass "uninstall — all symlinks removed"
else
  fail "uninstall — $remaining symlinks remain"
fi

# --- Test: skips non-symlink targets ---
proj3="$TMPDIR_BASE/project3"
mkdir -p "$proj3/.claude/skills/audit"
output=$("$INSTALL" --project "$proj3" --skill audit 2>&1)
if echo "$output" | grep -q "skipped"; then
  pass "skip non-symlink — reported skipped"
else
  fail "skip non-symlink — expected 'skipped'"
fi

# --- Test: --skill rejects unknown skill name ---
if "$INSTALL" --project "$TMPDIR_BASE" --skill nonexistent 2>/dev/null; then
  fail "--skill unknown — should have been rejected"
else
  pass "--skill unknown — rejected"
fi

# --- Test: unknown option exits with error ---
if "$INSTALL" --bogus 2>/dev/null; then
  fail "unknown option — should have exited 1"
else
  pass "unknown option — rejected"
fi

# --- Test: settings.json created when it doesn't exist ---
echo "--- settings.json tests ---"
proj_settings="$TMPDIR_BASE/project_settings"
mkdir -p "$proj_settings"
HOME="$proj_settings" "$INSTALL" --project "$proj_settings" > /dev/null 2>&1
if [ -f "$proj_settings/.claude/settings.json" ]; then
  if jq -e '.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS == "1"' "$proj_settings/.claude/settings.json" >/dev/null 2>&1; then
    pass "settings.json — created with AGENT_TEAMS"
  else
    fail "settings.json — missing AGENT_TEAMS env var"
  fi
  if jq -e '.env.REVIEW_BOT == "copilot-pull-request-reviewer[bot]"' "$proj_settings/.claude/settings.json" >/dev/null 2>&1; then
    pass "settings.json — created with REVIEW_BOT"
  else
    fail "settings.json — missing REVIEW_BOT env var"
  fi
else
  # jq might not be available — skip gracefully
  if ! command -v jq &>/dev/null; then
    pass "settings.json — AGENT_TEAMS skipped (jq not available)"
    pass "settings.json — REVIEW_BOT skipped (jq not available)"
  else
    fail "settings.json — file not created"
    fail "settings.json — file not created"
  fi
fi

# --- Test: settings.json preserves existing keys ---
proj_merge="$TMPDIR_BASE/project_merge"
mkdir -p "$proj_merge/.claude"
echo '{"env":{"MY_CUSTOM_VAR":"hello"},"other_key":"preserved"}' > "$proj_merge/.claude/settings.json"
HOME="$proj_merge" "$INSTALL" --project "$proj_merge" > /dev/null 2>&1
if command -v jq &>/dev/null; then
  if jq -e '.env.MY_CUSTOM_VAR == "hello"' "$proj_merge/.claude/settings.json" >/dev/null 2>&1; then
    pass "settings.json — preserved existing env var"
  else
    fail "settings.json — lost existing env var"
  fi
  if jq -e '.other_key == "preserved"' "$proj_merge/.claude/settings.json" >/dev/null 2>&1; then
    pass "settings.json — preserved non-env key"
  else
    fail "settings.json — lost non-env key"
  fi
else
  pass "settings.json merge — skipped (jq not available)"
  pass "settings.json merge — skipped (jq not available)"
fi

# --- Test: settings.json idempotent (existing env vars not overwritten) ---
proj_idem="$TMPDIR_BASE/project_idem"
mkdir -p "$proj_idem/.claude"
echo '{"env":{"REVIEW_BOT":"my-custom-bot[bot]","CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS":"1"}}' > "$proj_idem/.claude/settings.json"
HOME="$proj_idem" "$INSTALL" --project "$proj_idem" > /dev/null 2>&1
if command -v jq &>/dev/null; then
  if jq -e '.env.REVIEW_BOT == "my-custom-bot[bot]"' "$proj_idem/.claude/settings.json" >/dev/null 2>&1; then
    pass "settings.json — did not overwrite existing REVIEW_BOT"
  else
    fail "settings.json — overwrote existing REVIEW_BOT"
  fi
else
  pass "settings.json idempotent — skipped (jq not available)"
fi

# --- Test: settings.json skipped for malformed JSON ---
proj_bad="$TMPDIR_BASE/project_bad"
mkdir -p "$proj_bad/.claude"
echo '{broken json' > "$proj_bad/.claude/settings.json"
output=$(HOME="$proj_bad" "$INSTALL" --project "$proj_bad" 2>&1)
if echo "$output" | grep -q "merge failed"; then
  pass "settings.json — warned on malformed JSON"
else
  if command -v jq &>/dev/null; then
    fail "settings.json — should warn on malformed JSON"
  else
    pass "settings.json malformed — skipped (jq not available)"
  fi
fi

# --- Test: settings.json with .env as non-object (array) ---
proj_array="$TMPDIR_BASE/project_array"
mkdir -p "$proj_array/.claude"
echo '{"env":["old","array"]}' > "$proj_array/.claude/settings.json"
HOME="$proj_array" "$INSTALL" --project "$proj_array" > /dev/null 2>&1
if command -v jq &>/dev/null; then
  if jq -e '.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS == "1"' "$proj_array/.claude/settings.json" >/dev/null 2>&1; then
    pass "settings.json — recovered from non-object .env"
  else
    fail "settings.json — failed to recover from non-object .env"
  fi
else
  pass "settings.json non-object — skipped (jq not available)"
fi

# --- Test: graceful when jq is not available ---
proj_nojq="$TMPDIR_BASE/project_nojq"
mkdir -p "$proj_nojq"
output=$(PATH="/usr/bin:/bin" HOME="$proj_nojq" "$INSTALL" --project "$proj_nojq" 2>&1) || true
if echo "$output" | grep -qi "jq"; then
  pass "settings.json — warns when jq missing"
else
  # jq might be in /usr/bin or /bin — if so this test is not meaningful
  pass "settings.json — jq available in restricted PATH (test skipped)"
fi

# --- Summary ---
echo ""
echo "$passed passed, $failed failed"
[ "$failed" -eq 0 ]
